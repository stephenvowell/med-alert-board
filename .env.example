# Register at https://cloud.ouraring.com → API Applications
# Redirect URI must match exactly (local example below).
# For GoDaddy: https://YOUR-APP-URL/auth/callback — see deploy/GODADDY.md

OURA_CLIENT_ID=your_client_id
OURA_CLIENT_SECRET=your_client_secret

# Local dev — set explicitly:
OURA_REDIRECT_URI=http://localhost:3000/auth/callback

# GoDaddy / cloud — only CLIENT_ID + CLIENT_SECRET required in host UI.
# Redirect URI is auto-detected from your app URL, OR set one of:
# PUBLIC_URL=https://your-app.example.com
# OURA_REDIRECT_URI=https://your-app.example.com/auth/callback

PORT=3000
# HOST=0.0.0.0   # default; required for cloud hosting

# --- Alert thresholds (defaults shown) ---

# Yellow alert: latest HR or SpO₂ is this many points below 7-day average
ALERT_DROP_POINTS=10
ALERT_WINDOW_DAYS=7

# Yellow battery card + blue NeoPixel when ring battery is at or below this %
BATTERY_LOW_PERCENT=25

# Red HR card + flashing red NeoPixel when latest BPM is below this value
HR_CRITICAL_LOW_BPM=40

# --- Test mode (development only — do not use in production) ---
# ALERT_TEST_HEARTRATE=1
# ALERT_TEST_SPO2=1
# ALERT_TEST_BATTERY=1
# ALERT_TEST_HR_CRITICAL=1
